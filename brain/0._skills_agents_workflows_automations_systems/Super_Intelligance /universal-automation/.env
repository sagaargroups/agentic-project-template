# ═══════════════════════════════════════════════════════════════
# UNIVERSAL AUTOMATION 2.0 — MASTER ENVIRONMENT REGISTRY
# ═══════════════════════════════════════════════════════════════
#
# This is the SINGLE SOURCE OF TRUTH for the entire system.
# Every model, tool, channel, agent, and connector is registered here.
#
# HOW TO ADD A NEW TOOL:
#   1. Add the model to SECTION 1
#   2. Add the tool to SECTION 2
#   3. Assign the tool to an agent in SECTION 4
#   4. The Master God agent now sees and can use it
#
# HOW TO ADD A NEW CHANNEL:
#   1. Add to SECTION 3 with type (free/paid) and priority
#
# HOW TO ADD A NEW AGENT:
#   1. Add to SECTION 4 with role description and tool assignments
#   2. Create an AGENT.md in agents/ folder with full instructions
#
# ═══════════════════════════════════════════════════════════════


# ──────────────────────────────────────────────────────────────
# SECTION 1: AI MODELS (The Commanders)
# ──────────────────────────────────────────────────────────────
# Format: MODEL_[CATEGORY]_[NAME]=model_id|provider|free_tier_details|api_endpoint
#
# Categories: REASONING, IMAGE, VIDEO, AUDIO, CODE, DESIGN
# Providers: google, anthropic, openai, ideogram, recraft, blackforestlabs, kuaishou, runway, alibaba, elevenlabs
# Free Tier: free, free-limited, free-N-per-day, paid-only
# ──────────────────────────────────────────────────────────────

# ─── Reasoning / Writing Models ───
MODEL_REASONING_PRIMARY=gemini-2.5-pro|google|free-via-ai-studio|https://aistudio.google.com
MODEL_REASONING_FAST=gemini-2.5-flash|google|free-via-ai-studio|https://aistudio.google.com
MODEL_WRITING_CREATIVE=claude-sonnet-4.5|anthropic|free-5-msgs-rolling-5hr|https://claude.ai
MODEL_WRITING_GENERAL=chatgpt-4o|openai|free-limited-3hr-reset|https://chatgpt.com
MODEL_RESEARCH=perplexity-ai|perplexity|free-unlimited|https://perplexity.ai

# ─── Image Generation Models (VERIFIED FEB 2026) ───
# Nano Banana 2 = Gemini 3.1 Flash Image (LATEST - announced Feb 26, 2026)
# Features: 4K resolution, consistent characters (5 chars, 14 objects), real-time web knowledge
MODEL_IMAGE_NANOBANANA2=gemini-3.1-flash-image|google|free-via-ai-studio|https://aistudio.google.com
# Nano Banana Pro = Gemini 3 Pro Image (Nov 20, 2025)
# Features: Enhanced text rendering, world knowledge
MODEL_IMAGE_NANOBANANA_PRO=gemini-3-pro-image|google|free-via-ai-studio|https://aistudio.google.com
# Imagen 4 (Google's standalone diffusion model)
# Features: 2K photorealism, fast generation, text in images
MODEL_IMAGE_IMAGEN4=imagen-4|google|free-via-ai-studio|https://aistudio.google.com
# Ideogram 3 — Best for text-in-image rendering
MODEL_IMAGE_IDEOGRAM3=ideogram-3|ideogram|free-25-gens-per-day|https://ideogram.ai
# Recraft V4 — Vector/SVG generation, editable designs
MODEL_IMAGE_RECRAFT_V4=recraft-v4|recraft|free-30-gens-per-day|https://recraft.ai
# FLUX 2 Pro — Character consistency, ultra-realism
MODEL_IMAGE_FLUX2=flux-2-pro|blackforestlabs|free-limited-credits|https://flux1.ai
# Leonardo AI — Professional quality with fine control
MODEL_IMAGE_LEONARDO=leonardo-ai|leonardo|free-credits-daily|https://leonardo.ai
# Freepik AI — Mockups and stock-style images
MODEL_IMAGE_FREEPIK=freepik-ai|freepik|free-limited|https://freepik.com/ai
# Adobe Firefly — Commercially safe, licensed training data
MODEL_IMAGE_FIREFLY=adobe-firefly|adobe|free-limited|https://firefly.adobe.com

# ─── Video Generation Models (VERIFIED FEB 2026) ───
# Veo 3.1 (Jan 2026) — 4K, synced audio, vertical 9:16 for Shorts
MODEL_VIDEO_VEO31=veo-3.1|google|free-via-gemini-app|https://gemini.google.com
# Veo 3 (May 2025) — Video + dialogue + sound effects + ambient noise
MODEL_VIDEO_VEO3=veo-3|google|free-via-gemini-app|https://gemini.google.com
# Kling 3.0 — Multi-shot, physics-aware, native 4K, synced audio
MODEL_VIDEO_KLING3=kling-3.0|kuaishou|free-limited|https://klingai.com
# Runway Gen-4.5 — Cinematic filmmaking, camera choreography
MODEL_VIDEO_RUNWAY=runway-gen-4.5|runway|free-trial|https://runwayml.com
# Wan 2.1 — Open source, self-hosted, 1080p
MODEL_VIDEO_WAN=wan-2.1|alibaba|free-opensource|https://github.com/Wan-Video/Wan2.1

# ─── Audio / Music Generation Models (VERIFIED FEB 2026) ───
# Lyria 3 (Feb 2026) — 30-sec tracks, lyrics, auto cover art via Nano Banana
MODEL_AUDIO_LYRIA3=lyria-3|google|free-via-gemini-app|https://gemini.google.com
# Lyria RealTime (Jan 2026) — Live interactive music steering
MODEL_AUDIO_LYRIA_RT=lyria-realtime|google|free-experimental-api|https://aistudio.google.com
# ElevenLabs — Voice cloning, TTS, voiceover
MODEL_AUDIO_ELEVENLABS=elevenlabs|elevenlabs|free-10k-chars-monthly|https://elevenlabs.io

# ─── Code Generation Models ───
MODEL_CODE_PRIMARY=gemini-2.5-pro|google|free-via-ai-studio|https://aistudio.google.com
MODEL_CODE_AGENT=claude-sonnet-4.5|anthropic|free-limited|https://claude.ai


# ──────────────────────────────────────────────────────────────
# SECTION 2: TOOLS (What Agents Use)
# ──────────────────────────────────────────────────────────────
# Format: TOOL_[ACTION]=description|model_or_app|layer|status|free_limit|access_url
#
# Layers: creation, distribution, intelligence, connector
# Status: active, inactive, planned
# ──────────────────────────────────────────────────────────────

# ─── LAYER 1: CREATION TOOLS (Making the Signal) ───

TOOL_WRITE_BLOG=Long-form blog and article writing|MODEL_REASONING_PRIMARY|creation|active|free-unlimited-ai-studio|https://aistudio.google.com
TOOL_WRITE_CAPTION=Social media captions and short copy|MODEL_REASONING_FAST|creation|active|free-unlimited-ai-studio|https://aistudio.google.com
TOOL_WRITE_EMAIL=Email sequences and newsletters copy|MODEL_WRITING_CREATIVE|creation|active|free-5-msgs|https://claude.ai
TOOL_WRITE_SCRIPT=Video scripts and ad copy|MODEL_REASONING_PRIMARY|creation|active|free|https://aistudio.google.com
TOOL_WRITE_SEO=SEO-optimized content with keywords|MODEL_REASONING_PRIMARY|creation|active|free|https://aistudio.google.com

TOOL_IMAGE_PRODUCT=Product photography and hero shots|MODEL_IMAGE_NANOBANANA2|creation|active|free-ai-studio|https://aistudio.google.com
TOOL_IMAGE_SOCIAL=Social media post graphics|MODEL_IMAGE_NANOBANANA2|creation|active|free-ai-studio|https://aistudio.google.com
TOOL_IMAGE_AD=Advertisement and banner visuals|MODEL_IMAGE_NANOBANANA_PRO|creation|active|free-ai-studio|https://aistudio.google.com
TOOL_IMAGE_LOGO=Logo and brand mark creation|MODEL_IMAGE_IDEOGRAM3|creation|active|free-25-per-day|https://ideogram.ai
TOOL_IMAGE_VECTOR=Vector/SVG assets and editable designs|MODEL_IMAGE_RECRAFT_V4|creation|active|free-30-per-day|https://recraft.ai
TOOL_IMAGE_MOCKUP=Product mockups and packaging visualization|MODEL_IMAGE_FREEPIK|creation|active|free-limited|https://freepik.com/ai
TOOL_IMAGE_TEXT=Images with perfect text rendering|MODEL_IMAGE_IDEOGRAM3|creation|active|free-25-per-day|https://ideogram.ai
TOOL_IMAGE_CONSISTENT=Character-consistent multi-image sets|MODEL_IMAGE_NANOBANANA2|creation|active|free|https://aistudio.google.com

TOOL_VIDEO_PRODUCT=Product showcase videos|MODEL_VIDEO_VEO31|creation|active|free-gemini|https://gemini.google.com
TOOL_VIDEO_AD=Advertisement and promo videos|MODEL_VIDEO_VEO3|creation|active|free-gemini|https://gemini.google.com
TOOL_VIDEO_REEL=Short-form vertical videos (Reels/Shorts)|MODEL_VIDEO_VEO31|creation|active|free-vertical-native|https://gemini.google.com
TOOL_VIDEO_CINEMATIC=High-quality cinematic footage|MODEL_VIDEO_KLING3|creation|active|free-limited|https://klingai.com
TOOL_VIDEO_EDIT=Video editing, auto-captions, transitions|capcut|creation|active|free|https://capcut.com

TOOL_MUSIC_JINGLE=Brand jingles and background music|MODEL_AUDIO_LYRIA3|creation|active|free-gemini|https://gemini.google.com
TOOL_MUSIC_UNDERSCORE=Background audio for videos|MODEL_AUDIO_LYRIA3|creation|active|free|https://gemini.google.com
TOOL_VOICE_OVER=Voiceover and narration|MODEL_AUDIO_ELEVENLABS|creation|active|free-10k-chars|https://elevenlabs.io

TOOL_DESIGN_TEMPLATE=Brand kit, locked templates, social formats|canva|creation|active|free-tier|https://canva.com
TOOL_DESIGN_UI=UI/UX design, website mockups, brand systems|figma|creation|active|free-individual|https://figma.com

# ─── LAYER 2: DISTRIBUTION TOOLS (Firing the Signal) ───

TOOL_POST_SOCIAL=Schedule and auto-post to social media|buffer|distribution|active|free-3-channels-10-posts|https://buffer.com
TOOL_POST_SOCIAL_ALT=Schedule with analytics and competitor watch|metricool|distribution|active|free-1-brand-50-posts|https://metricool.com
TOOL_POST_API=Programmatic social posting via API|ayrshare|distribution|active|free-10-networks-20-posts|https://ayrshare.com
TOOL_EMAIL_SEND=Email marketing, sequences, broadcasts|mailchimp|distribution|active|free-500-contacts|https://mailchimp.com
TOOL_WHATSAPP=Direct messaging, catalog, broadcast|whatsapp-business|distribution|active|free|https://business.whatsapp.com
TOOL_GOOGLE_BUSINESS=Local search presence, reviews, posts|google-business-profile|distribution|active|free|https://business.google.com
TOOL_WEBSITE_PUBLISH=Website and blog CMS|wordpress|distribution|active|free-self-hosted|https://wordpress.org
TOOL_LANDING_PAGE=Single page sites and conversion pages|carrd|distribution|active|free-tier|https://carrd.co
TOOL_LINK_BIO=Link-in-bio for all social profiles|linktree|distribution|active|free|https://linktr.ee
TOOL_META_DIRECT=Facebook and Instagram native scheduling|meta-business-suite|distribution|active|free-unlimited|https://business.facebook.com

# ─── LAYER 3: INTELLIGENCE TOOLS (Reading What Happened) ───

TOOL_ANALYTICS_WEB=Website traffic, conversions, user behavior|google-analytics-4|intelligence|active|free|https://analytics.google.com
TOOL_ANALYTICS_SEO=Search rankings, indexing, click-through|google-search-console|intelligence|active|free|https://search.google.com/search-console
TOOL_ANALYTICS_DASHBOARD=Custom visual reporting combining all data|looker-studio|intelligence|active|free|https://lookerstudio.google.com
TOOL_ANALYTICS_SOCIAL=Facebook and Instagram reach/engagement|meta-business-suite|intelligence|active|free|https://business.facebook.com
TOOL_ANALYTICS_KEYWORDS=SEO keywords and competitor analysis|ubersuggest|intelligence|active|free-limited|https://neilpatel.com/ubersuggest
TOOL_ANALYTICS_HEATMAP=User recordings, scroll depth, click maps|hotjar|intelligence|active|free-tier|https://hotjar.com

# ─── LAYER 4: CONNECTOR TOOLS (The Middle-Men) ───

TOOL_CONNECTOR_SHEETS=Central operations database (content calendar, task tracker, asset log)|google-sheets|connector|active|free|https://sheets.google.com
TOOL_CONNECTOR_NOTION=Knowledge base, docs, databases, content planning|notion|connector|active|free-individual|https://notion.so
TOOL_CONNECTOR_AFFINE=Local-first knowledge base, whiteboards, databases|affine|connector|active|free-open-source|https://affine.pro
TOOL_CONNECTOR_N8N=Webhook triggers, cron scheduling, API bridges|n8n|connector|active|free-self-hosted|https://n8n.io
TOOL_CONNECTOR_BROWSER=Web browsing, research, scraping|browser|connector|active|free|built-in
TOOL_CONNECTOR_FILESYSTEM=Read/write local project files|filesystem|connector|active|free|built-in
TOOL_CONNECTOR_TERMINAL=Execute system commands|terminal|connector|active|free|built-in


# ──────────────────────────────────────────────────────────────
# SECTION 3: CHANNELS (Where Outcomes Arrive)
# ──────────────────────────────────────────────────────────────
# Format: CHANNEL_[NAME]=platform|type(free/paid)|status|priority|connector_tool
#
# Type: free = organic (no money), paid = amplified (costs money)
# Priority: 1 = highest priority to establish first
# Connector: Which tool from Section 2 posts to this channel
# ──────────────────────────────────────────────────────────────

# ─── FREE / ORGANIC CHANNELS (Build The Engine) ───
CHANNEL_WEBSITE=custom-website|free|active|1|TOOL_WEBSITE_PUBLISH
CHANNEL_GOOGLE_BIZ=google-business-profile|free|active|2|TOOL_GOOGLE_BUSINESS
CHANNEL_WHATSAPP=whatsapp-business|free|active|3|TOOL_WHATSAPP
CHANNEL_FACEBOOK=facebook-page|free|active|4|TOOL_META_DIRECT
CHANNEL_INSTAGRAM=instagram|free|active|5|TOOL_POST_SOCIAL
CHANNEL_YOUTUBE=youtube|free|active|6|TOOL_POST_SOCIAL
CHANNEL_LINKEDIN=linkedin-company|free|active|7|TOOL_POST_SOCIAL
CHANNEL_EMAIL_LIST=mailchimp-list|free|active|8|TOOL_EMAIL_SEND
CHANNEL_SEO=google-search-organic|free|active|9|TOOL_ANALYTICS_SEO
CHANNEL_BLOG=blog-content-hub|free|active|10|TOOL_WEBSITE_PUBLISH

# ─── PAID / AMPLIFIED CHANNELS (Pour The Fuel) ───
CHANNEL_GOOGLE_ADS=google-ads|paid|inactive|1|none-manual
CHANNEL_META_ADS=meta-ads-fb-ig|paid|inactive|2|none-manual
CHANNEL_YOUTUBE_ADS=youtube-ads|paid|inactive|3|none-manual
CHANNEL_LINKEDIN_ADS=linkedin-ads|paid|inactive|4|none-manual
CHANNEL_INFLUENCER=influencer-pr|paid|inactive|5|none-manual


# ──────────────────────────────────────────────────────────────
# SECTION 4: AGENTS (Who Uses The Tools)
# ──────────────────────────────────────────────────────────────
# Format: AGENT_[ROLE]=description|assigned_tools(csv)|storage_location|status
#
# Storage Location: Where this agent writes its work output
# (so the next agent in the chain can read it)
# ──────────────────────────────────────────────────────────────

AGENT_BRAND_ARCHITECT=Guards identity and visual consistency|TOOL_DESIGN_TEMPLATE,TOOL_DESIGN_UI,TOOL_IMAGE_VECTOR,TOOL_IMAGE_LOGO,TOOL_IMAGE_TEXT|knowledge/brand/|active
AGENT_CONTENT_CREATOR=Creates all content: text, image, video, audio|TOOL_WRITE_BLOG,TOOL_WRITE_CAPTION,TOOL_WRITE_SCRIPT,TOOL_WRITE_SEO,TOOL_IMAGE_PRODUCT,TOOL_IMAGE_SOCIAL,TOOL_IMAGE_AD,TOOL_IMAGE_CONSISTENT,TOOL_VIDEO_PRODUCT,TOOL_VIDEO_AD,TOOL_VIDEO_REEL,TOOL_VIDEO_EDIT,TOOL_MUSIC_JINGLE,TOOL_VOICE_OVER|CONNECTOR_SHEETS:content-queue|active
AGENT_PUBLISHER=Distributes content to all channels on schedule|TOOL_POST_SOCIAL,TOOL_POST_SOCIAL_ALT,TOOL_POST_API,TOOL_EMAIL_SEND,TOOL_WHATSAPP,TOOL_META_DIRECT,TOOL_WEBSITE_PUBLISH|CONNECTOR_SHEETS:publish-log|active
AGENT_GROWTH_MANAGER=Drives organic discovery via SEO and community|TOOL_ANALYTICS_SEO,TOOL_ANALYTICS_KEYWORDS,TOOL_GOOGLE_BUSINESS,TOOL_WRITE_SEO|CONNECTOR_SHEETS:seo-tracker|active
AGENT_PAID_MEDIA=Manages ads and paid amplification|TOOL_POST_SOCIAL,TOOL_ANALYTICS_SOCIAL|CONNECTOR_SHEETS:ad-tracker|inactive
AGENT_CONVERSATION_MGR=Handles all inbound: DMs, emails, chatbot|TOOL_WHATSAPP,TOOL_EMAIL_SEND,TOOL_WRITE_CAPTION|CONNECTOR_SHEETS:conversation-log|active
AGENT_SALES=Turns leads into customers: CRM, proposals|TOOL_WRITE_BLOG,TOOL_EMAIL_SEND,TOOL_LANDING_PAGE|CONNECTOR_SHEETS:sales-pipeline|active
AGENT_INTELLIGENCE=Reads all analytics, generates reports|TOOL_ANALYTICS_WEB,TOOL_ANALYTICS_SEO,TOOL_ANALYTICS_DASHBOARD,TOOL_ANALYTICS_SOCIAL,TOOL_ANALYTICS_HEATMAP|CONNECTOR_SHEETS:weekly-report|active
AGENT_FINANCE_OPS=Invoicing, payments, admin operations|TOOL_WRITE_BLOG,TOOL_CONNECTOR_FILESYSTEM|CONNECTOR_SHEETS:finance-log|active


# ──────────────────────────────────────────────────────────────
# SECTION 5: MASTER GOD AGENT
# ──────────────────────────────────────────────────────────────
# The supreme orchestrator. Has DIRECT access to:
#   - Every tool (all 50+)
#   - Every agent (all 9)
#   - Every channel (all 15)
#   - The central connector (Google Sheets / Notion / AFFiNE)
# Receives reports from ALL agents.
# Makes strategic decisions and delegates work.
# ──────────────────────────────────────────────────────────────

MASTER_GOD=supreme-orchestrator|ALL_TOOLS,ALL_AGENTS,ALL_CHANNELS,ALL_CONNECTORS|active
MASTER_GOD_REPORTING_FROM=AGENT_BRAND_ARCHITECT,AGENT_CONTENT_CREATOR,AGENT_PUBLISHER,AGENT_GROWTH_MANAGER,AGENT_PAID_MEDIA,AGENT_CONVERSATION_MGR,AGENT_SALES,AGENT_INTELLIGENCE,AGENT_FINANCE_OPS
MASTER_GOD_CONNECTOR=TOOL_CONNECTOR_SHEETS|master-dashboard-tab


# ──────────────────────────────────────────────────────────────
# SECTION 6: CONNECTOR LAYER CONFIGURATION
# ──────────────────────────────────────────────────────────────
# The MIDDLE-MAN — where agents store work and read from each other.
#
# PRIMARY CONNECTOR: Google Sheets (free, API accessible, real-time)
# SECONDARY: Notion (for docs/knowledge) or AFFiNE (local-first)
# TRIGGER: n8n (for cron/webhook-based automation)
#
# Google Sheet Tabs (one per agent workflow):
# ──────────────────────────────────────────────────────────────

CONNECTOR_PRIMARY=google-sheets
CONNECTOR_SECONDARY=notion-or-affine
CONNECTOR_TRIGGER=n8n

# Sheet Tab: content-queue
# Columns: ID | Brand | Content Type | Platform | Caption | Image URL | Video URL | Status | Scheduled Date | Created By Agent
SHEET_TAB_CONTENT_QUEUE=content-queue|Content Creator writes here|Publisher reads from here

# Sheet Tab: publish-log
# Columns: ID | Brand | Platform | Post URL | Published At | Engagement | Notes
SHEET_TAB_PUBLISH_LOG=publish-log|Publisher writes here|Intelligence reads from here

# Sheet Tab: seo-tracker
# Columns: ID | Keyword | Current Rank | Target Rank | Page URL | Last Checked | Action Needed
SHEET_TAB_SEO_TRACKER=seo-tracker|Growth Manager writes here|Content Creator reads for SEO content

# Sheet Tab: weekly-report
# Columns: ID | Week | Channel | Impressions | Clicks | Engagement Rate | Top Post | Recommendation
SHEET_TAB_WEEKLY_REPORT=weekly-report|Intelligence writes here|Master God reads for decisions

# Sheet Tab: sales-pipeline
# Columns: ID | Lead Name | Source | Stage | Value | Last Contact | Next Action
SHEET_TAB_SALES_PIPELINE=sales-pipeline|Sales agent writes here|Conversation Mgr reads for follow-up

# Sheet Tab: conversation-log
# Columns: ID | Platform | Customer | Message | Response | Sentiment | Escalate?
SHEET_TAB_CONVERSATION_LOG=conversation-log|Conversation Mgr writes here|Sales reads for warm leads

# Sheet Tab: master-dashboard
# Columns: Agent | Last Report | Status | Key Metric | Action Taken | Next Task
SHEET_TAB_MASTER_DASHBOARD=master-dashboard|All agents report here|Master God reads here


