<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>20% Questions → 80% Understanding</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --font-sans: system-ui, -apple-system, sans-serif;
    --color-bg: #ffffff;
    --color-bg-secondary: #f5f5f3;
    --color-text-primary: #1a1a1a;
    --color-text-secondary: #6b6b6b;
    --color-text-tertiary: #a0a0a0;
    --color-border: rgba(0,0,0,0.12);
    --color-border-hover: rgba(0,0,0,0.25);
    --radius-md: 8px;
    --radius-lg: 12px;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --color-bg: #1c1c1c;
      --color-bg-secondary: #2a2a2a;
      --color-text-primary: #f0f0f0;
      --color-text-secondary: #a0a0a0;
      --color-text-tertiary: #666;
      --color-border: rgba(255,255,255,0.12);
      --color-border-hover: rgba(255,255,255,0.25);
    }
  }

  body {
    font-family: var(--font-sans);
    background: var(--color-bg);
    color: var(--color-text-primary);
    padding: 2rem 1.5rem;
    max-width: 760px;
    margin: 0 auto;
    line-height: 1.6;
  }

  h2 { font-size: 20px; font-weight: 500; margin-bottom: 6px; }
  .subtitle { font-size: 14px; color: var(--color-text-secondary); margin-bottom: 1.5rem; }

  .input-row { display: flex; gap: 10px; margin-bottom: 1rem; }
  .input-row input {
    flex: 1; padding: 10px 14px;
    border: 0.5px solid var(--color-border-hover);
    border-radius: var(--radius-md);
    font-size: 15px; font-family: var(--font-sans);
    background: var(--color-bg); color: var(--color-text-primary);
    outline: none;
  }
  .input-row input:focus { border-color: #888; }
  .input-row button, .footer-row button, .q-actions button {
    padding: 10px 18px;
    border: 0.5px solid var(--color-border-hover);
    border-radius: var(--radius-md);
    background: var(--color-bg); color: var(--color-text-primary);
    font-size: 14px; font-family: var(--font-sans);
    cursor: pointer;
  }
  .input-row button:hover, .footer-row button:hover { background: var(--color-bg-secondary); }
  .input-row button:disabled { opacity: 0.45; cursor: not-allowed; }

  .params-row { display: flex; gap: 10px; margin-bottom: 1.25rem; flex-wrap: wrap; }
  .param-box {
    background: var(--color-bg-secondary);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 8px 14px;
    display: flex; align-items: center; gap: 10px;
  }
  .param-box label { font-size: 13px; color: var(--color-text-secondary); white-space: nowrap; }
  .param-box select, .param-box input[type=number] {
    border: none; background: transparent;
    font-size: 13px; font-family: var(--font-sans);
    color: var(--color-text-primary); outline: none;
  }
  .param-box select { width: 140px; }
  .param-box input[type=number] { width: 50px; }

  .status { font-size: 13px; color: var(--color-text-secondary); margin-bottom: 1rem; min-height: 20px; }

  .progress-bar { height: 4px; background: var(--color-bg-secondary); border-radius: 99px; margin-bottom: 1.25rem; overflow: hidden; display: none; }
  .progress-fill { height: 100%; background: #1D9E75; border-radius: 99px; transition: width 0.4s ease; }

  .q-list { display: flex; flex-direction: column; gap: 12px; }
  .q-card {
    background: var(--color-bg);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1rem 1.25rem;
    transition: border-color 0.2s;
  }
  .q-card.done { border-left: 3px solid #1D9E75; }
  .q-card.skipped { opacity: 0.45; }

  .q-top { display: flex; align-items: flex-start; gap: 10px; }
  .q-num { font-size: 12px; font-weight: 500; color: var(--color-text-tertiary); min-width: 22px; padding-top: 3px; }
  .q-text { font-size: 15px; line-height: 1.6; flex: 1; }

  .q-actions { display: flex; gap: 6px; margin-left: auto; flex-shrink: 0; }
  .q-actions button { padding: 4px 10px; font-size: 12px; }
  .q-actions button:hover { background: var(--color-bg-secondary); }
  .q-actions button.active { background: #E1F5EE; color: #0F6E56; border-color: #5DCAA5; }

  .tag {
    display: inline-block; font-size: 11px; font-weight: 500;
    padding: 2px 8px; border-radius: var(--radius-md);
    margin-right: 6px; margin-top: 6px;
  }
  .tag.core    { background: #E1F5EE; color: #0F6E56; }
  .tag.concept { background: #EEEDFE; color: #3C3489; }
  .tag.process { background: #FAEEDA; color: #633806; }
  .tag.risk    { background: #FCEBEB; color: #791F1F; }

  .why-toggle {
    font-size: 12px; color: var(--color-text-tertiary);
    cursor: pointer; margin-top: 6px; display: inline-block;
  }
  .why-toggle:hover { color: var(--color-text-secondary); }

  .q-why {
    margin-top: 10px; padding: 10px 12px;
    background: var(--color-bg-secondary);
    border-radius: var(--radius-md);
    font-size: 13px; color: var(--color-text-secondary);
    line-height: 1.6; display: none;
  }
  .q-why.open { display: block; }

  .q-note {
    margin-top: 8px; width: 100%;
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 6px 10px;
    font-size: 13px; font-family: var(--font-sans);
    background: var(--color-bg); color: var(--color-text-primary);
    resize: none; display: none; outline: none;
  }
  .q-note.open { display: block; }

  .footer-row { display: flex; gap: 10px; margin-top: 1.5rem; flex-wrap: wrap; display: none; }
  .footer-row button { padding: 8px 16px; font-size: 13px; }

  .api-notice {
    font-size: 12px; color: var(--color-text-tertiary);
    margin-top: 1.5rem; padding-top: 1rem;
    border-top: 0.5px solid var(--color-border);
  }
  .api-notice a { color: var(--color-text-secondary); }

  .key-row { display: flex; gap: 8px; margin-bottom: 1rem; }
  .key-row input {
    flex: 1; padding: 8px 12px;
    border: 0.5px solid var(--color-border-hover);
    border-radius: var(--radius-md);
    font-size: 13px; font-family: var(--font-sans);
    background: var(--color-bg); color: var(--color-text-primary);
    outline: none;
  }
  .key-save {
    padding: 8px 14px !important;
    font-size: 13px !important;
  }
</style>
</head>
<body>

<h2>20% Questions → 80% Understanding</h2>
<p class="subtitle">Koi bhi topic daalo — Pareto principle pe based key questions milenge, har ek ke saath "kyun yeh poochha" ka reason.</p>

<div class="key-row">
  <input type="password" id="apiKey" placeholder="Anthropic API key daalo (sk-ant-...)" />
  <button class="key-save" onclick="saveKey()">Save Key</button>
</div>

<div class="input-row">
  <input type="text" id="topicInput" placeholder="Topic daalo — GST, Python, Stock Market, Photography..." />
  <button id="generateBtn" onclick="generate()">Generate ↗</button>
</div>

<div class="params-row">
  <div class="param-box">
    <label>Questions</label>
    <input type="number" id="qCount" value="10" min="5" max="20" />
  </div>
  <div class="param-box">
    <label>Level</label>
    <select id="levelSel">
      <option value="absolute beginner">Bilkul Beginner</option>
      <option value="some exposure" selected>Thoda Pata Hai</option>
      <option value="intermediate">Intermediate</option>
    </select>
  </div>
  <div class="param-box">
    <label>Goal</label>
    <select id="goalSel">
      <option value="practical use" selected>Practical Use</option>
      <option value="concept clarity">Concept Clarity</option>
      <option value="business application">Business Use</option>
      <option value="exam or interview">Exam / Interview</option>
    </select>
  </div>
</div>

<div class="progress-bar" id="progressBar">
  <div class="progress-fill" id="progressFill" style="width:0%"></div>
</div>

<div class="status" id="status"></div>
<div class="q-list" id="qList"></div>

<div class="footer-row" id="footerRow">
  <button onclick="exportNotes()">Notes export karo (copy)</button>
  <button onclick="resetAll()">Reset</button>
</div>

<div class="api-notice">
  Yeh tool Anthropic Claude API use karta hai. API key
  <a href="https://console.anthropic.com" target="_blank">console.anthropic.com</a>
  se milegi. Key sirf is browser session mein store hoti hai.
</div>

<script>
let questions = [];
let done = new Set();
let skipped = new Set();
let apiKey = '';

function saveKey() {
  apiKey = document.getElementById('apiKey').value.trim();
  if (apiKey) {
    document.getElementById('status').textContent = 'API key saved. Ab topic daalo!';
    sessionStorage.setItem('ak', apiKey);
  }
}

window.onload = () => {
  const saved = sessionStorage.getItem('ak');
  if (saved) {
    apiKey = saved;
    document.getElementById('apiKey').value = saved;
  }
};

async function generate() {
  const topic = document.getElementById('topicInput').value.trim();
  if (!topic) { document.getElementById('status').textContent = 'Topic daalo pehle!'; return; }
  if (!apiKey) { document.getElementById('status').textContent = 'API key save karo pehle!'; return; }

  const qCount = document.getElementById('qCount').value;
  const level   = document.getElementById('levelSel').value;
  const goal    = document.getElementById('goalSel').value;

  document.getElementById('generateBtn').disabled = true;
  document.getElementById('qList').innerHTML = '';
  document.getElementById('footerRow').style.display = 'none';
  document.getElementById('progressBar').style.display = 'none';
  done.clear(); skipped.clear(); questions = [];
  document.getElementById('status').textContent = 'Generating...';

  const prompt = `You are a Pareto learning expert. For the topic "${topic}", generate exactly ${qCount} questions that represent the 20% of knowledge giving 80% understanding.

User level: ${level}
User goal: ${goal}

Rules:
- Questions must be foundational — answering them unlocks most other knowledge
- Each question must be atomic (one concept per question)
- Include variety: definitions, processes, risks, decisions
- Tag each question as one of: core, concept, process, risk
- Write questions in simple Hinglish or English — whichever fits the topic

Return ONLY valid JSON array, no markdown, no explanation:
[
  {
    "q": "question text",
    "why": "2-3 line explanation of WHY this question is in the 20% list — what unlocks by knowing this",
    "tag": "core|concept|process|risk"
  }
]`;

  try {
    const res = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "x-api-key": apiKey,
        "anthropic-version": "2023-06-01",
        "anthropic-dangerous-direct-browser-access": "true"
      },
      body: JSON.stringify({
        model: "claude-opus-4-20250514",
        max_tokens: 1500,
        messages: [{ role: "user", content: prompt }]
      })
    });
    const data = await res.json();
    if (data.error) throw new Error(data.error.message);
    let raw = data.content.map(c => c.text || '').join('');
    raw = raw.replace(/```json|```/g, '').trim();
    questions = JSON.parse(raw);
    render();
  } catch(e) {
    document.getElementById('status').textContent = 'Error: ' + e.message;
  }
  document.getElementById('generateBtn').disabled = false;
}

function render() {
  const list = document.getElementById('qList');
  list.innerHTML = '';
  document.getElementById('progressBar').style.display = 'block';
  document.getElementById('footerRow').style.display = 'flex';
  updateProgress();

  questions.forEach((q, i) => {
    const card = document.createElement('div');
    card.className = 'q-card' + (done.has(i) ? ' done' : '') + (skipped.has(i) ? ' skipped' : '');
    card.id = 'card-' + i;
    card.innerHTML = `
      <div class="q-top">
        <span class="q-num">${i + 1}.</span>
        <div style="flex:1">
          <div class="q-text">${q.q}</div>
          <span class="tag ${q.tag}">${q.tag}</span>
          <span class="why-toggle" onclick="toggleWhy(${i})">▸ Yeh kyun poochha?</span>
          <div class="q-why" id="why-${i}">${q.why}</div>
          <textarea class="q-note" id="note-${i}" rows="2" placeholder="Apna answer ya notes yahan likho..."></textarea>
        </div>
        <div class="q-actions">
          <button onclick="markDone(${i})" class="${done.has(i) ? 'active' : ''}">Done</button>
          <button onclick="addNote(${i})">Note</button>
          <button onclick="toggleSkip(${i})">Skip</button>
        </div>
      </div>`;
    list.appendChild(card);
  });
}

function toggleWhy(i) {
  const el = document.getElementById('why-' + i);
  const tog = el.previousElementSibling;
  el.classList.toggle('open');
  tog.textContent = el.classList.contains('open') ? '▾ Yeh kyun poochha?' : '▸ Yeh kyun poochha?';
}

function addNote(i) {
  const el = document.getElementById('note-' + i);
  el.classList.toggle('open');
  if (el.classList.contains('open')) el.focus();
}

function markDone(i) {
  if (done.has(i)) done.delete(i); else done.add(i);
  skipped.delete(i);
  render();
}

function toggleSkip(i) {
  if (skipped.has(i)) skipped.delete(i); else skipped.add(i);
  render();
}

function updateProgress() {
  const pct = questions.length ? Math.round((done.size / questions.length) * 100) : 0;
  document.getElementById('progressFill').style.width = pct + '%';
  document.getElementById('status').textContent =
    `${questions.length} questions — ${done.size} complete — ${pct}% done`;
}

function exportNotes() {
  const topic = document.getElementById('topicInput').value;
  let out = `TOPIC: ${topic}\n${'─'.repeat(40)}\n\n`;
  questions.forEach((q, i) => {
    const note = document.getElementById('note-' + i)?.value || '';
    const status = done.has(i) ? '[DONE]' : skipped.has(i) ? '[SKIP]' : '[    ]';
    out += `${status} Q${i + 1} [${q.tag.toUpperCase()}]: ${q.q}\n`;
    out += `  WHY: ${q.why}\n`;
    if (note) out += `  MY NOTE: ${note}\n`;
    out += '\n';
  });
  navigator.clipboard.writeText(out).then(() => {
    document.getElementById('status').textContent = 'Notes clipboard mein copy ho gaye!';
  });
}

function resetAll() {
  done.clear(); skipped.clear(); questions = [];
  document.getElementById('qList').innerHTML = '';
  document.getElementById('status').textContent = '';
  document.getElementById('progressBar').style.display = 'none';
  document.getElementById('footerRow').style.display = 'none';
  document.getElementById('topicInput').value = '';
}

document.getElementById('topicInput').addEventListener('keydown', e => {
  if (e.key === 'Enter') generate();
});
</script>
</body>
</html>
